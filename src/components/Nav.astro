---
const pathname = Astro.url.pathname;

const links = [
  { href: '/about', label: 'about' },
  { href: '/cv', label: 'cv' },
  { href: '/projects', label: 'projects' },
  { href: '/contact', label: 'contact' },
];
---

<nav>
  <a href="/" class="logo">>_ adir_tuval</a>
  <ul>
    {links.map(({ href, label }) => (
      <li>
        <a href={href} class={pathname === href || pathname === href + '/' ? 'active' : ''}>
          {label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2rem;
    height: var(--nav-height);
    background-color: var(--bg);
    border-bottom: 1px solid var(--border);
  }

  .logo {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--accent);
    text-decoration: none;
    text-shadow: 0 0 7px var(--accent);
    transition: text-shadow 0.2s;
  }

  .logo:hover {
    text-shadow: 0 0 12px var(--accent), 0 0 25px rgba(0, 255, 65, 0.4);
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 0.25rem;
  }

  ul a {
    display: block;
    padding: 0.4rem 0.6rem;
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.15s, text-shadow 0.15s;
    position: relative;
  }

  ul a::before {
    content: '[';
    opacity: 0;
    transition: opacity 0.15s;
  }

  ul a::after {
    content: ']';
    opacity: 0;
    transition: opacity 0.15s;
  }

  ul a:hover::before,
  ul a:hover::after,
  ul a.active::before,
  ul a.active::after {
    opacity: 1;
  }

  ul a:hover {
    color: var(--text);
  }

  @keyframes nav-glitch {
    0% { clip-path: inset(0 0 0 0); }
    25% { clip-path: inset(0 0 0 -3px); }
    50% { clip-path: inset(0 -2px 0 0); }
    75% { clip-path: inset(0 0 0 2px); }
    100% { clip-path: inset(0 0 0 0); }
  }

  ul a:hover {
    animation: nav-glitch 0.15s steps(4);
  }

  ul a.active {
    color: var(--accent);
    text-shadow: 0 0 7px var(--accent);
  }

  @media (max-width: 768px) {
    nav {
      flex-direction: column;
      height: auto;
      padding: 1rem;
      gap: 0.75rem;
    }

    ul {
      gap: 0.15rem;
    }
  }
</style>
