---
import Nav from '../components/Nav.astro';

interface Props {
  title?: string;
  description?: string;
  schema?: Record<string, unknown>;
}

const { title = 'Adir Tuval', description = 'Adir Tuval — Algorithm developer at Mobileye and CS graduate student at Hebrew University. Portfolio showcasing projects, skills, and experience.', schema } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="canonical" href={canonicalURL.href} />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fira+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL('/og-image.png', Astro.site).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og-image.png', Astro.site).href} />

    {schema && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}
  </head>
  <body>
    <Nav />
    <slot />
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
  }

  :root {
    --bg: #0a0a0a;
    --bg-subtle: #111111;
    --surface: #1a1a1a;
    --border: #333333;
    --text: #cccccc;
    --text-muted: #666666;
    --accent: #00ff41;
    --accent-secondary: #ffb000;
    --radius: 0px;
    --nav-height: 56px;
  }

  html {
    scroll-behavior: smooth;
  }

  html, body {
    margin: 0;
    padding: 0;
    width: 100%;
    min-height: 100%;
  }

  body {
    background-color: var(--bg);
    color: var(--text);
    font-family: 'Fira Mono', 'Courier New', monospace;
    font-size: 14px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  /* CRT Vignette */
  body::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(ellipse at center, transparent 60%, rgba(0, 0, 0, 0.45) 100%);
    pointer-events: none;
    z-index: 9998;
  }

  /* CRT Scanlines */
  body::after {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 1px,
      rgba(0, 0, 0, 0.08) 1px,
      rgba(0, 0, 0, 0.08) 2px
    );
    pointer-events: none;
    z-index: 9999;
  }

  /* CRT Screen Flicker */
  @keyframes flicker {
    0% { opacity: 1; }
    5% { opacity: 0.98; }
    10% { opacity: 1; }
    15% { opacity: 0.97; }
    20% { opacity: 1; }
    100% { opacity: 1; }
  }

  body {
    animation: flicker 4s infinite;
  }

  /* Selection */
  ::selection {
    background-color: var(--accent);
    color: #000;
  }

  /* Phosphor glow utility */
  .glow {
    text-shadow: 0 0 7px var(--accent), 0 0 15px rgba(0, 255, 65, 0.3);
  }

  a {
    color: var(--accent);
    text-decoration: none;
    transition: text-shadow 0.2s;
  }

  a:hover {
    text-shadow: 0 0 7px var(--accent);
  }
</style>
