---
import Layout from '../layouts/Layout.astro';

const experience = [
  {
    role: 'Algorithm Developer',
    org: 'Mobileye',
    dates: '2021 — Present',
    description:
      'Developing algorithms for autonomous driving systems. Working on perception and decision-making pipelines using Python and C++.',
  },
  {
    role: 'Tech Support Engineer',
    org: 'Bezeq International',
    dates: '2018',
    description:
      'Provided technical support and troubleshooting for internet infrastructure and customer-facing network issues.',
  },
];

const education = [
  {
    role: 'M.Sc. Computer Science',
    org: 'Hebrew University of Jerusalem',
    dates: '2023 — Present',
    description: 'GPA: 93.5. Focus on machine learning and algorithms.',
  },
  {
    role: 'B.Sc. Computer Science',
    org: 'Hebrew University of Jerusalem',
    dates: 'Graduated',
    description: 'GPA: 91.2. Coursework in algorithms, systems programming, and machine learning.',
  },
  {
    role: 'Science & Technology Track',
    org: 'High School Ra\'anana',
    dates: '2011 — 2014',
    description: 'Science and technology specialization.',
  },
];

const skills = [
  { category: 'Python', items: ['NumPy', 'Pandas', 'PyTorch'] },
  { category: 'C++ / C', items: ['Advanced OOP', 'Systems Programming'] },
  { category: 'Linux', items: ['Bash', 'Shell Scripting'] },
];

const languages = [
  { name: 'Hebrew', level: 'Native' },
  { name: 'English', level: 'Fluent' },
];
---

<Layout title="CV — Adir Tuval" description="Adir Tuval's CV — Algorithm developer at Mobileye, M.Sc. Computer Science at Hebrew University. Experience in Python, C++, machine learning, and autonomous driving.">
  <main>
    <div class="header">
      <h1><span class="prompt">cat</span> cv.txt</h1>
      <a href="/CV.pdf" download class="download-btn">$ download cv.pdf</a>
    </div>

    <section class="flicker-in" style="--delay: 0.1s">
      <h2>═══ Experience ═══</h2>
      <div class="timeline">
        {experience.map((entry) => (
          <article class="entry">
            <div class="entry-meta">
              <span class="dates">{entry.dates}</span>
            </div>
            <div class="entry-body">
              <h3>&gt; {entry.role}</h3>
              <span class="org">@ {entry.org}</span>
              <p>{entry.description}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="flicker-in" style="--delay: 0.3s">
      <h2>═══ Education ═══</h2>
      <div class="timeline">
        {education.map((entry) => (
          <article class="entry">
            <div class="entry-meta">
              <span class="dates">{entry.dates}</span>
            </div>
            <div class="entry-body">
              <h3>&gt; {entry.role}</h3>
              <span class="org">@ {entry.org}</span>
              <p>{entry.description}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="flicker-in" style="--delay: 0.5s">
      <h2>═══ Skills ═══</h2>
      <div class="skills-grid">
        {skills.map((skill) => (
          <div class="skill-group">
            <span class="skill-category">{skill.category}</span>
            <div class="skill-tags">
              {skill.items.map((item) => (
                <span class="skill-tag">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="flicker-in" style="--delay: 0.7s">
      <h2>═══ Languages ═══</h2>
      <div class="languages">
        {languages.map((lang) => (
          <span class="lang-item">{lang.name} <span class="lang-level">[{lang.level}]</span></span>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style>
  main {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 3rem;
  }

  h1 {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0;
    color: var(--text);
  }

  .prompt {
    color: var(--accent);
    text-shadow: 0 0 7px var(--accent);
  }

  .download-btn {
    display: inline-block;
    padding: 0.5rem 1.2rem;
    border: 1px solid var(--accent);
    color: var(--accent);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    position: relative;
    overflow: hidden;
    z-index: 1;
    transition: color 0.3s;
  }

  .download-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 0;
    height: 100%;
    background-color: var(--accent);
    z-index: -1;
    transition: width 0.3s ease;
  }

  .download-btn:hover {
    color: #000;
    text-shadow: none;
  }

  .download-btn:hover::before {
    width: 100%;
  }

  /* Flicker-in animation */
  .flicker-in {
    opacity: 0;
    animation: flicker-in 0.4s ease forwards;
    animation-delay: var(--delay, 0s);
  }

  @keyframes flicker-in {
    0% { opacity: 0; }
    10% { opacity: 0.4; }
    20% { opacity: 0.1; }
    30% { opacity: 0.6; }
    50% { opacity: 0.3; }
    70% { opacity: 0.8; }
    100% { opacity: 1; }
  }

  section {
    margin-bottom: 3rem;
  }

  h2 {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    text-shadow: 0 0 7px var(--accent);
    margin: 0 0 1.5rem;
    padding-bottom: 0;
    border-bottom: none;
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .entry {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 1.5rem;
    padding: 0.75rem;
    border-left: 2px solid var(--border);
    transition: border-color 0.2s;
  }

  .entry:hover {
    border-left-color: var(--accent);
  }

  .entry-meta {
    padding-top: 0.15rem;
  }

  .dates {
    font-size: 0.8rem;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .entry-body h3 {
    margin: 0 0 0.2rem;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text);
  }

  .org {
    display: block;
    font-size: 0.85rem;
    color: var(--accent-secondary);
    margin-bottom: 0.6rem;
  }

  .entry-body p {
    margin: 0;
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  /* Skills */
  .skills-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .skill-group {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .skill-category {
    font-size: 0.85rem;
    color: var(--accent-secondary);
    min-width: 80px;
    font-weight: 700;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .skill-tag {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border: 1px solid var(--accent);
    font-size: 0.75rem;
    color: var(--accent);
  }

  /* Languages */
  .languages {
    display: flex;
    gap: 1.5rem;
  }

  .lang-item {
    font-size: 0.9rem;
    color: var(--text);
  }

  .lang-level {
    color: var(--text-muted);
  }

  @media (max-width: 560px) {
    .entry {
      grid-template-columns: 1fr;
      gap: 0.4rem;
    }
  }
</style>
