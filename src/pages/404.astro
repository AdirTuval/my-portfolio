---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Page Not Found" description="The page you're looking for doesn't exist.">
  <main>
    <section class="error-page">
      <h1><span class="prompt">404</span></h1>
      <p class="message">&gt; Error: file not found</p>
      <p class="hint">The path you requested does not exist on this system.</p>
      <nav class="actions">
        <a href="/" class="cmd">$ cd ~</a>
        <a href="/projects" class="cmd">$ ls projects/</a>
        <a href="/about" class="cmd">$ whoami</a>
      </nav>
    </section>
  </main>
</Layout>

<style>
  main {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100dvh - var(--nav-height));
    padding: 2rem;
  }

  .error-page {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  h1 {
    font-size: 4rem;
    margin: 0;
    color: var(--text);
  }

  .prompt {
    color: var(--accent);
    text-shadow: 0 0 10px var(--accent), 0 0 25px rgba(0, 255, 65, 0.3);
  }

  .message {
    font-size: 1.1rem;
    color: var(--accent-secondary);
    margin: 0;
  }

  .hint {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin: 0 0 1rem;
  }

  .actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .cmd {
    padding: 0.5rem 1.2rem;
    border: 1px solid var(--border);
    color: var(--text);
    text-decoration: none;
    font-size: 0.9rem;
    transition: border-color 0.2s, color 0.2s, text-shadow 0.2s, background-color 0.2s;
  }

  .cmd:hover {
    border-color: var(--accent);
    color: var(--accent);
    text-shadow: 0 0 7px var(--accent);
    background-color: rgba(0, 255, 65, 0.05);
  }
</style>
