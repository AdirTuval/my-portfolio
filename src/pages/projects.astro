---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: 'DevTrack',
    description:
      'A lightweight issue tracker built with Node.js and PostgreSQL. Features real-time updates, labels, and markdown support.',
    tags: ['TypeScript', 'Node.js', 'PostgreSQL'],
    href: '#',
  },
  {
    title: 'Patchwork',
    description:
      'A CLI tool that automates dependency updates across monorepos, with support for npm, pnpm, and yarn workspaces.',
    tags: ['Python', 'CLI', 'Open Source'],
    href: '#',
  },
  {
    title: 'Spectral',
    description:
      'A minimal music player for the web. Streams local audio files with a waveform visualizer built on the Web Audio API.',
    tags: ['React', 'Web Audio API', 'Vite'],
    href: '#',
  },
];
---

<Layout title="Projects — Adir Tuval">
  <main>
    <h1><span class="prompt">ls</span> ~/projects/</h1>
    <p class="lead">&gt; 3 items found. More on GitHub.</p>

    <div class="grid">
      {projects.map((project, i) => (
        <article class="card flicker-in" style={`--delay: ${0.1 + i * 0.2}s`}>
          <div class="title-bar">
            <span class="window-controls">[x] [-] [_]</span>
            <span class="window-title">{project.title}</span>
          </div>
          <div class="card-body">
            <p>{project.description}</p>
            <div class="tags">
              {project.tags.map((tag) => (
                <span class="tag">#{tag}</span>
              ))}
            </div>
          </div>
          <div class="card-footer">
            <a href={project.href} class="project-link">$ open project →</a>
          </div>
        </article>
      ))}
    </div>
  </main>
</Layout>

<style>
  main {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  h1 {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 0.5rem;
    color: var(--text);
  }

  .prompt {
    color: var(--accent);
    text-shadow: 0 0 7px var(--accent);
  }

  .lead {
    margin: 0 0 3rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Flicker-in */
  .flicker-in {
    opacity: 0;
    animation: flicker-in 0.4s ease forwards;
    animation-delay: var(--delay, 0s);
  }

  @keyframes flicker-in {
    0% { opacity: 0; }
    10% { opacity: 0.4; }
    20% { opacity: 0.1; }
    30% { opacity: 0.6; }
    50% { opacity: 0.3; }
    70% { opacity: 0.8; }
    100% { opacity: 1; }
  }

  /* Terminal window card */
  .card {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    background-color: var(--surface);
    transition: border-color 0.3s, box-shadow 0.3s;
  }

  .card:hover {
    border-color: var(--accent);
    box-shadow: 0 0 15px rgba(0, 255, 65, 0.1), 0 0 30px rgba(0, 255, 65, 0.05);
  }

  .title-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0.75rem;
    background-color: var(--bg-subtle);
    border-bottom: 1px solid var(--border);
    font-size: 0.8rem;
  }

  .window-controls {
    color: var(--text-muted);
    font-size: 0.7rem;
    letter-spacing: 0.05em;
  }

  .window-title {
    color: var(--accent-secondary);
    font-weight: 700;
  }

  .card-body {
    padding: 1.25rem;
    flex: 1;
  }

  .card-body p {
    margin: 0 0 1rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.7;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.75rem;
    color: var(--accent);
  }

  .card-footer {
    padding: 0.75rem 1.25rem;
    border-top: 1px solid var(--border);
  }

  .project-link {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.85rem;
    transition: color 0.2s, text-shadow 0.2s;
  }

  .project-link:hover {
    color: var(--accent);
    text-shadow: 0 0 7px var(--accent);
  }
</style>
