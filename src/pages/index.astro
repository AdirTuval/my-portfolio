---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Adir Tuval">
  <main>
    <div class="glow" aria-hidden="true"></div>
    <section class="hero">
      <p class="eyebrow">Hi, I'm</p>
      <h1 class="name">Adir Tuval</h1>
      <p class="subtitle">Developer &amp; maker of things.</p>
      <div class="cta">
        <a href="/projects" class="btn-primary">View Projects →</a>
        <a href="/about" class="btn-ghost">About me</a>
      </div>
    </section>
  </main>
</Layout>

<style>
  main {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100dvh - var(--nav-height));
    overflow: hidden;
    text-align: center;
    padding: 2rem;
  }

  .glow {
    position: absolute;
    top: -200px;
    left: 50%;
    transform: translateX(-50%);
    width: 700px;
    height: 500px;
    background: radial-gradient(ellipse at center, var(--accent-glow) 0%, transparent 70%);
    pointer-events: none;
  }

  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .eyebrow {
    margin: 0;
    font-size: 1.25rem;
    color: var(--text-muted);
    font-weight: 400;
  }

  .name {
    margin: 0;
    font-size: clamp(3rem, 10vw, 6rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    background: linear-gradient(135deg, #a5b4fc, var(--accent), #818cf8, #c7d2fe);
    background-size: 300% 300%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: gradient-shift 6s ease infinite;
  }

  @keyframes gradient-shift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .subtitle {
    margin: 0.25rem 0 0;
    font-size: 1.2rem;
    color: var(--text-muted);
  }

  .cta {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-primary {
    display: inline-block;
    padding: 0.65rem 1.5rem;
    border-radius: var(--radius);
    background-color: var(--accent);
    color: #fff;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: opacity 0.2s, transform 0.2s;
  }

  .btn-primary:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .btn-ghost {
    display: inline-block;
    padding: 0.65rem 1.5rem;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    color: var(--text);
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: border-color 0.2s, transform 0.2s;
  }

  .btn-ghost:hover {
    border-color: var(--accent);
    transform: translateY(-1px);
  }
</style>
