---
import Layout from '../layouts/Layout.astro';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Adir Tuval',
  url: 'https://adirtuval.com',
  jobTitle: 'Algorithm Developer',
  worksFor: { '@type': 'Organization', name: 'Mobileye' },
  alumniOf: { '@type': 'CollegeOrUniversity', name: 'Hebrew University of Jerusalem' },
  knowsAbout: ['Python', 'C++', 'Machine Learning', 'Computer Vision', 'Autonomous Driving'],
  sameAs: ['https://github.com/AdirTuval'],
};
---

<Layout title="Adir Tuval ‚ÄĒ Algorithm Developer & CS Student" description="Adir Tuval ‚ÄĒ Algorithm developer at Mobileye and CS graduate student at Hebrew University. Building autonomous driving systems, ML pipelines, and open-source tools." schema={personSchema}>
  <main>
    <section class="hero">
      <h1 class="sr-only">Adir Tuval ‚ÄĒ Algorithm Developer & CS Student</h1>
      <div class="ascii-name" aria-label="Adir Tuval">
        <pre class="glitch-target">{`
 ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó
‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó
‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ
‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó
‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ
‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ`}</pre>
      </div>

      <div class="subtitle-wrap">
        <span class="subtitle">&gt; algorithm developer &amp; cs student</span>
      </div>

      <div class="cta boot-4">
        <a href="/projects" class="cmd">$ cat projects</a>
        <a href="/about" class="cmd">$ whoami</a>
      </div>
    </section>
  </main>
</Layout>

<style>
  main {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100dvh - var(--nav-height));
    overflow: hidden;
    padding: 2rem;
  }

  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  /* Boot sequence */
  .ascii-name,
  .subtitle-wrap,
  .cta {
    opacity: 0;
    transform: translateY(12px);
    animation: boot-in 0.5s ease forwards;
  }

  .ascii-name { animation-delay: 0.2s; }
  .subtitle-wrap { animation-delay: 0.7s; }
  .cta { animation-delay: 1.2s; }

  @keyframes boot-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ASCII Art Name */
  .ascii-name pre {
    margin: 0;
    font-size: clamp(0.35rem, 1.8vw, 0.85rem);
    line-height: 1.2;
    color: var(--accent);
    text-shadow: 0 0 10px var(--accent), 0 0 25px rgba(0, 255, 65, 0.3);
    text-align: center;
    cursor: default;
  }

  /* Glitch effect on hover */
  .glitch-target {
    position: relative;
  }

  .ascii-name:hover .glitch-target {
    animation: glitch 0.3s steps(3) 1;
  }

  @keyframes glitch {
    0% {
      text-shadow: 0 0 10px var(--accent), 0 0 25px rgba(0, 255, 65, 0.3);
      clip-path: inset(0 0 0 0);
    }
    20% {
      text-shadow: -3px 0 #ff0000, 3px 0 #00ffff, 0 0 10px var(--accent);
      clip-path: inset(20% 0 40% 0);
    }
    40% {
      text-shadow: 3px 0 #ff0000, -3px 0 #00ffff, 0 0 10px var(--accent);
      clip-path: inset(60% 0 10% 0);
    }
    60% {
      text-shadow: -2px 0 #ff0000, 2px 0 #00ffff, 0 0 10px var(--accent);
      clip-path: inset(10% 0 70% 0);
    }
    80% {
      text-shadow: 2px 0 #ff0000, -2px 0 #00ffff, 0 0 10px var(--accent);
      clip-path: inset(50% 0 20% 0);
    }
    100% {
      text-shadow: 0 0 10px var(--accent), 0 0 25px rgba(0, 255, 65, 0.3);
      clip-path: inset(0 0 0 0);
    }
  }

  /* Typewriter subtitle */
  .subtitle-wrap {
    overflow: hidden;
  }

  .subtitle {
    display: inline-block;
    overflow: hidden;
    white-space: nowrap;
    border-right: 2px solid var(--accent);
    width: 0;
    animation:
      typing 2s steps(34) 0.8s forwards,
      blink 0.7s step-end infinite 0.8s;
    color: var(--accent-secondary);
    font-size: 1rem;
  }

  @keyframes typing {
    to { width: 100%; }
  }

  @keyframes blink {
    50% { border-color: transparent; }
  }

  /* CTA Links */
  .cta {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .cmd {
    padding: 0.5rem 1.2rem;
    border: 1px solid var(--border);
    color: var(--text);
    text-decoration: none;
    font-size: 0.9rem;
    transition: border-color 0.2s, color 0.2s, text-shadow 0.2s, background-color 0.2s;
  }

  .cmd:hover {
    border-color: var(--accent);
    color: var(--accent);
    text-shadow: 0 0 7px var(--accent);
    background-color: rgba(0, 255, 65, 0.05);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  @media (max-width: 600px) {
    .ascii-name pre {
      font-size: clamp(0.25rem, 4vw, 0.55rem);
    }
  }
</style>
